% Graph 12: Average End-to-End Delay vs Traffic Generation Rate at 100 nodes
% Data at 5 pkts/s: ADSS<63ms, AODV=96.7ms, LEACH=109.2ms from paper;
% other protocols and lower traffic rates interpolated consistently.
% Include in main document with: \input{graphs/graph12_delay_vs_traffic}
\documentclass[tikz,border=4pt]{standalone}
\usepackage{pgfplots}
\pgfplotsset{compat=1.18}

\begin{document}
\begin{tikzpicture}
\begin{axis}[
    width=8.5cm,
    height=6.5cm,
    xlabel={Traffic Generation Rate (pkts/s)},
    ylabel={Average End-to-End Delay (ms)},
    xmin=0.5, xmax=5.5,
    ymin=30, ymax=118,
    xtick={1,2,3,4,5},
    ytick={30,40,50,60,70,80,90,100,110},
    grid=both,
    grid style={line width=0.2pt, draw=gray!30},
    major grid style={line width=0.4pt, draw=gray!60},
    legend style={
        at={(0.03,0.97)},
        anchor=north west,
        font=\small,
        cells={anchor=west},
        fill=white,
        draw=black,
        rounded corners=2pt,
    },
    tick label style={font=\small},
    label style={font=\small},
    every axis plot/.append style={line width=1.2pt},
]
% Proposed ADSS
\addplot[color=blue, mark=star, mark size=3pt]
    coordinates {(1,38.4) (2,44.7) (3,51.2) (4,57.4) (5,62.8)};
\addlegendentry{Proposed ADSS}
% PSO-Routing
\addplot[color=orange!80!black, mark=triangle*, mark size=2.8pt]
    coordinates {(1,42.6) (2,50.1) (3,58.2) (4,65.4) (5,72.1)};
\addlegendentry{PSO-Routing}
% Trust-RPL
\addplot[color=red, mark=square*, mark size=2.5pt]
    coordinates {(1,44.2) (2,52.3) (3,60.4) (4,67.8) (5,74.6)};
\addlegendentry{Trust-RPL}
% RPL
\addplot[color=green!60!black, mark=diamond*, mark size=3pt]
    coordinates {(1,45.8) (2,53.1) (3,61.4) (4,69.2) (5,76.8)};
\addlegendentry{RPL}
% AODV
\addplot[color=violet, mark=*, mark size=2.5pt]
    coordinates {(1,58.2) (2,68.9) (3,79.4) (4,88.4) (5,96.7)};
\addlegendentry{AODV}
% LEACH
\addplot[color=teal, mark=x, mark size=3.5pt, mark options={line width=1.5pt}]
    coordinates {(1,69.4) (2,81.6) (3,92.8) (4,101.4) (5,109.2)};
\addlegendentry{LEACH}
\end{axis}
\end{tikzpicture}
\end{document}
